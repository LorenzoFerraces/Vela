# Copy to demo.live.env and fill in for `npm run demo:record:live`.
# PowerShell: Get-Content demo.live.env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { Set-Item -Path "env:$($matches[1].Trim())" -Value $matches[2].Trim() } }

# App and API (defaults: Vite :5173, FastAPI :8000)
# VELA_DEMO_APP_URL=http://127.0.0.1:5173
# VELA_DEMO_API_URL=http://127.0.0.1:8000

# Demo account (must exist; GitHub connected if you show the Settings GitHub card)
VELA_DEMO_EMAIL=demo@example.com
VELA_DEMO_PASSWORD=change-me-min-8-chars

# Git repo for the analyze scene (must be reachable with your connected GitHub token if private)
VELA_DEMO_GIT_SEARCH=github.com/your-org/your-repo
VELA_DEMO_GIT_OPTION=your-org/your-repo

# Optional: assert @handle on Settings; omit to only show the GitHub section
# VELA_DEMO_GITHUB_LOGIN=your-github-handle

# Optional: skip seeding a stopped container for dashboard ordering (faster)
# VELA_DEMO_SKIP_STOPPED_SEED=1

# Optional: custom public URL regex after deploy (default matches http(s) URLs)
# VELA_DEMO_PUBLIC_URL_PATTERN=https://.*\.yourdomain\.dev/
